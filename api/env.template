# Subtitle Tool API Environment Configuration Template
# Copy this file to .env and adjust the values as needed
# 
# IMPORTANT: You don't need to set all variables!
# Only uncomment and modify the ones you want to change from defaults.
# All variables have sensible defaults and will work without this file.

# ===========================================
# ESSENTIAL CONFIGURATION (Most Important)
# ===========================================

# Maximum concurrent transcription tasks (default: 3)
# Higher values will use more CPU/GPU resources
# MAX_CONCURRENT_TASKS=3

# Maximum concurrent video-to-audio conversion tasks (default: 2)
# FFmpeg operations are relatively lightweight
# MAX_CONCURRENT_CONVERT_TASKS=2

# ===========================================
# WHISPER MODEL CONFIGURATION
# ===========================================

# Whisper model size (tiny, base, small, medium, large, large-v2, large-v3)
# Larger models are more accurate but slower and use more resources
# WHISPER_MODEL_SIZE=base

# Device to use for Whisper inference (cpu, cuda, mps)
# cuda: NVIDIA GPU, mps: Apple Silicon GPU, cpu: CPU only
# WHISPER_DEVICE=cpu

# ===========================================
# OPTIONAL CONFIGURATION (Advanced Users)
# ===========================================

# Temporary directory for file processing
# Leave empty to use system default temp directory
# TEMP_DIR=

# Maximum file size for uploads (in bytes)
# Default: 100MB
# MAX_FILE_SIZE=104857600

# Chunk size for large file uploads (in bytes)
# Default: 5MB
# CHUNK_SIZE=5242880

# Enable noise reduction by default
# DEFAULT_DENOISE=false

# Audio quality settings for conversion
# high: 320kbps, medium: 192kbps, low: 128kbps
# DEFAULT_AUDIO_QUALITY=medium

# Default audio format for conversion
# DEFAULT_AUDIO_FORMAT=mp3

# Default language for transcription (auto-detect if empty)
# Examples: en, zh, ja, ko, es, fr, de, etc.
# DEFAULT_LANGUAGE=

# Enable Chinese punctuation restoration
# Requires zhpr model weights
# ENABLE_ZH_PUNCTUATION=false

# ===========================================
# MEETING NOTES PROVIDER (OpenAI-compatible)
# ===========================================

# OpenAI-compatible API base URL
# Example: https://api.openai.com/v1
# MEETING_NOTES_API_BASE=

# OpenAI-compatible API key
# MEETING_NOTES_API_KEY=

# Model name for meeting notes generation
# Example: gpt-4.1-mini / local-vllm-model
# MEETING_NOTES_MODEL=

# Request timeout in seconds
# MEETING_NOTES_TIMEOUT_SECONDS=30

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Log format (json, text)
# LOG_FORMAT=text

# Enable debug mode
# DEBUG=false

# Enable hot reload for development
# RELOAD=false

# Cleanup interval in seconds (default: 3600 = 1 hour)
# CLEANUP_INTERVAL=3600

# Maximum age of temporary files in seconds (default: 86400 = 24 hours)
# MAX_FILE_AGE=86400
